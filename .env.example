# Copy to .env and fill in your values. Never commit .env.
# Wadeny backend. Future environment changes = swap this base URL only.
API_BASE_URL=https://app.telefreik.com
API_KEY=

# Google Maps / Places (private transfer location pick).
# Enable in Google Cloud Console for this key:
#   - Places API (New)  — autocomplete + place details (places.googleapis.com/v1)
#   - Geocoding API       — reverse geocode for GPS / map pin
#   - Maps SDK for Android — native map in adjust sheet
GOOGLE_MAPS_API_KEY=

