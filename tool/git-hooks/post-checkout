#!/usr/bin/env sh
# REGO: after switching branches, re-apply the AGP-9 pub-cache plugin patch
# (see tool/README.md). $3 == 1 marks a branch checkout; skip file checkouts.
# Safe no-op if dependencies aren't fetched yet or `dart` isn't on PATH.
[ "$3" = "1" ] || exit 0
root="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
[ -f "$root/.dart_tool/package_config.json" ] || exit 0
command -v dart >/dev/null 2>&1 || exit 0
dart run "$root/tool/patch_android_plugins.dart" || true
